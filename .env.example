# API key for authenticating callers to this A2A server
# Choose a strong random value (e.g. a UUID). Callers must send: X-API-Key: <value>
API_KEY=your_a2a_server_api_key

# Google Maps Platform API key from Google Cloud Console
# Required APIs: Geocoding, Places, Directions, Distance Matrix
# See docs/google-maps-setup.md for setup instructions
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Log verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Deployment smoke tests (test_deployment.py)
A2A_URL=https://google-maps-a2a.fly.dev
A2A_API_KEY=your_a2a_server_api_key

# Optional: comma-separated IP addresses allowed to call this server
# Leave empty to allow all IPs. See docs/security.md for details.
ALLOWED_IPS=
